# Optional remote backend. Create the bucket/table first, then rename this file
# to backend.tf and update the values.
terraform {
  backend "s3" {
    bucket         = "replace-with-application-state-bucket"
    key            = "NSP-4-S2-S25App/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "replace-with-terraform-lock-table"
    encrypt        = true
  }
}
